# ==========================================
# Raja Banks Trading Bot - Configuration
# Copy this file to .env and fill in values
# ==========================================

# === BOT MODE ===
DRY_RUN=true                    # true = paper trading, false = live
INITIAL_BALANCE=10000           # Starting paper balance
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR

# === INSTRUMENT ===
SYMBOL=GC=F                     # Yahoo Finance symbol (GC=F = Gold Futures)
TIMEFRAME=15m                   # Bar timeframe

# === RISK MANAGEMENT ===
RISK_PERCENT=1.0                # Risk % per trade
MAX_TRADES_PER_DAY=3            # Max trades per day
DAILY_LOSS_LIMIT=3.0            # Max daily drawdown %

# === SESSION FILTER (UTC) ===
SESSION_START=8                 # Start trading at 08:00 UTC
SESSION_END=21                  # Stop trading at 21:00 UTC
BLACKOUT_START=13               # Skip 13:00-16:00 UTC (NY overlap)
BLACKOUT_END=16

# === STOP LOSS ===
MIN_SL_PIPS=20                  # Min SL distance (pips)
MAX_RISK_PIPS=55                # Max SL distance (pips)

# === TELEGRAM NOTIFICATIONS ===
TELEGRAM_ENABLED=false          # Enable Telegram alerts
TELEGRAM_BOT_TOKEN=             # Get from @BotFather on Telegram
TELEGRAM_CHAT_ID=               # Your chat ID (get from @userinfobot)
STATUS_INTERVAL_MIN=60          # Status update interval (minutes)

# === LEARNING AGENT ===
LEARNING_INTERVAL=10            # Re-analyze patterns every N trades
MIN_TRADES_BLOCK=15             # Min trades before blocking a pattern

# === DEPLOYMENT ===
PORT=8080                       # Health check port (Railway sets this)
DATA_DIR=data                   # Persistent data directory
UPDATE_INTERVAL=30              # Main loop interval (seconds)
