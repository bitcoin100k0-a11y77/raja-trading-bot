# ==============================================
# ANi's FX Bot — Environment Variables
# Copy values into RUN_BOT.ps1 before launching
# ==============================================

# === MT5 CONNECTION (⚠️ ENV REQUIRED) ===
MT5_LOGIN=                      # Your MT5 account number
MT5_PASSWORD=                   # Your MT5 password
MT5_SERVER=                     # Broker server, e.g. "ICMarkets-Demo"
MT5_SYMBOL=XAUUSD               # Gold symbol (check your broker — may be GOLD or XAU/USD)
MT5_MAGIC=20260402              # Magic number identifying bot orders

# === KILL SWITCH (📵) ===
LIVE_MODE=false                 # false = shadow mode (logs but no real orders)
                                # true  = REAL ORDERS SENT — use with extreme care

# === TELEGRAM ALERTS (📲) ===
TELEGRAM_BOT_TOKEN=             # Get from @BotFather on Telegram
TELEGRAM_CHAT_ID=               # Get from @userinfobot on Telegram

# === RISK MANAGEMENT ===
RISK_PERCENT=1.0                # % of account balance risked per trade
MAX_TRADES_PER_DAY=3            # Hard cap — stops new entries after this
DAILY_LOSS_LIMIT=4.0            # % drawdown triggers circuit breaker + shutdown

# === STRATEGY TUNING (safe defaults — only change if you know why) ===
MIN_SL_PIPS=10.0                # Min SL distance (C1 wick tip SL is tighter under stop-order model; 20p inherited from old C0-market-entry model)
REJECTION_TOLERANCE=8.0         # $8 zone-entry tolerance (XAUUSD M15 range $5–15)
MIN_ROOM_PIPS=15.0              # Minimum room to opposing S/R before entry
MAX_MID_RANGE_PCT=0.50          # Block entries in mid-range dead zone (50%)

# === C1/C0 QUALITY FILTERS ===
# C0 is now a VALIDATION GATE, not final entry bar.
# Actual entry = pending STOP order at C1 extreme + C1_STOP_BUFFER_PIPS.
C0_MIN_WICK_PIPS=5.0            # Min C0 wick depth (pips) — gate for stop placement (C1 breakout = real filter)
C0_MAX_DISTANCE_FROM_ZONE_PIPS=50.0  # Max pips between C0 open and S/R zone (loosened: 30→50)
SR_MIN_STRENGTH=2               # Min pivot clusters per S/R zone (1=too loose, 2=meaningful)
SR_MIN_BODY_TOUCHES=2           # Min bar bodies touching zone (2=catch fresh 2-touch reactions)
PENDING_EXPIRY_BARS=2           # C0 validation window: 2 bars (30 min). 1 gets eaten by same-bar guard before gates evaluate.
C1_STOP_BUFFER_PIPS=2.0         # Pips above C1 high (BUY_STOP) / below C1 low (SELL_STOP) for trigger

# === SESSION FILTER (UTC) ===
SESSION_START=8                 # Start trading at 08:00 UTC (London open — do NOT go below 8, Asia session overtrades)
SESSION_END=22                  # Stop trading at 22:00 UTC
BLACKOUT_START=11               # Skip 11:00–14:00 UTC (London/NY crossover)
BLACKOUT_END=14

# === TRAILING STOP ===
TRAILING_ENABLED=true
TRAILING_ACTIVATION_PIPS=50.0   # Start trailing after +50 pip profit
TRAILING_DISTANCE_PIPS=20.0     # Trail 20 pips behind peak price

# === MT5 CONNECTION TUNING ===
MT5_SLIPPAGE=20                 # Max slippage in points (20 = $2 on XAUUSD)
MT5_FILLING=IOC                 # Order filling: IOC or RETURN (broker-specific)

# === LOGGING ===
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
DATA_DIR=data                   # Data directory (db + logs)
UPDATE_INTERVAL=30              # Main loop interval in seconds
